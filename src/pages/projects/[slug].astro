---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ProjectDetailApp from "../../app/ProjectDetailApp";
import { projects } from "../../app/components/Projects";
import "../../styles/index.css";

export function getStaticPaths() {
  return projects.map((p) => ({
    params: { slug: p.slug },
    props: { title: p.title, impact: p.impact, github: p.github, tags: p.tags },
  }));
}

const { slug } = Astro.params;
const { title, impact, github, tags } = Astro.props;

const canonical = `https://ashit-upadhyay.vercel.app/projects/${slug}`;

const softwareSchema = {
  "@context": "https://schema.org",
  "@type": "SoftwareSourceCode",
  "name": title,
  "author": {
    "@type": "Person",
    "name": "Ashit Upadhyay",
    "url": "https://ashit-upadhyay.vercel.app"
  },
  "description": impact,
  "programmingLanguage": tags.slice(0, 3).join(", "),
  ...(github ? { "codeRepository": github } : {}),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://ashit-upadhyay.vercel.app/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": title,
      "item": canonical
    }
  ]
};
---

<BaseLayout
  title={`${title} | Ashit Upadhyay`}
  description={`${title} - ${impact}`}
  canonical={canonical}
  jsonLd={[softwareSchema, breadcrumbSchema]}
>
  <ProjectDetailApp slug={slug} client:idle />
</BaseLayout>
