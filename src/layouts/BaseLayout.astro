---
import { ClientRouter } from "astro:transitions";
import { PageBackground } from "../app/components/PageBackground";
import { ClockWidget } from "../app/components/ClockWidget";
import "@fontsource/playfair-display/800.css";
import "@fontsource/playfair-display/400-italic.css";
import "@fontsource/dm-sans/400.css";
import "@fontsource/dm-sans/500.css";
import "@fontsource/dm-sans/600.css";
import "@fontsource/dm-mono/400.css";
import dmSans400Url from "@fontsource/dm-sans/files/dm-sans-latin-400-normal.woff2?url";
import playfair800Url from "@fontsource/playfair-display/files/playfair-display-latin-800-normal.woff2?url";
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  jsonLd?: object[];
}

const {
  title = "Ashit Upadhyay - AI & ML Student",
  description = "3rd-year AI & ML student at Vishveshwarya Group of Institutions, building small ML and web projects while learning the fundamentals.",
  canonical = "https://ashit-upadhyay.vercel.app/",
  image = "https://ashit-upadhyay.vercel.app/og-image.jpg",
  jsonLd = [],
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <link rel="preload" href={dmSans400Url} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={playfair800Url} as="font" type="font/woff2" crossorigin="anonymous" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Ashit Upadhyay" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:image:width" content="1512" />
    <meta property="og:image:height" content="788" />
    <meta property="og:image:alt" content="Ashit Upadhyay - AI & ML Student. Building and shipping small AI/ML projects while learning." />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />

    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <ClientRouter />
    <slot name="head" />
  </head>
  <body>
    <PageBackground client:idle transition:persist="site-bg" />
    <ClockWidget client:idle transition:persist="clock-widget" />
    <div transition:persist="bottom-fade" style="position:fixed;bottom:0;left:0;right:0;height:5.5rem;background:linear-gradient(to top,rgba(6,6,8,0.72) 0%,transparent 100%);pointer-events:none;z-index:48;" />
    <slot />
  </body>
</html>
